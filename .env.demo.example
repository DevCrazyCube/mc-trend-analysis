# Demo mode — synthetic data, no external API keys required.
# Copy to .env and run: python -m mctrend.runner --demo --once

ENVIRONMENT=demo
DATABASE_PATH=data/mctrend_demo.db
LOG_LEVEL=INFO
LOG_FORMAT=console

# Leave these empty for demo mode — adapters will use synthetic data
NEWSAPI_KEY=
SERPAPI_KEY=
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
WEBHOOK_URL=
WEBHOOK_SECRET=
