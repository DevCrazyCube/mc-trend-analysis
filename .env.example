# =============================================================================
# MC Trend Analysis — Environment Configuration
# =============================================================================
# Copy this file to .env and fill in the required values.
# All values shown are defaults unless marked (required).
# =============================================================================

# --- Data Sources -----------------------------------------------------------

# Solana RPC endpoint for on-chain data access (required)
SOLANA_RPC_URL=https://api.mainnet-beta.solana.com

# Pump.fun API base URL (optional — falls back to on-chain monitoring)
PUMPFUN_API_URL=

# NewsAPI.org key for news narrative detection (optional)
NEWSAPI_KEY=

# SerpAPI key for Google Trends search data (optional)
SERPAPI_KEY=

# X/Twitter API bearer token for social signal ingestion (optional)
TWITTER_BEARER_TOKEN=

# --- Delivery Channels ------------------------------------------------------

# Telegram bot token for push alert delivery (optional)
TELEGRAM_BOT_TOKEN=

# Telegram chat ID to send alerts to (optional)
TELEGRAM_CHAT_ID=

# --- Storage ----------------------------------------------------------------

# Path to the SQLite database file (default: data/mctrend.db)
DATABASE_PATH=data/mctrend.db

# --- Logging ----------------------------------------------------------------

# Log level: DEBUG, INFO, WARNING, ERROR, CRITICAL (default: INFO)
LOG_LEVEL=INFO

# Log output format: json or console (default: json)
LOG_FORMAT=json

# --- Polling Intervals ------------------------------------------------------

# How often to poll for new token launches, in seconds (default: 30)
POLLING_INTERVAL_TOKENS=30

# How often to poll for narrative/event updates, in seconds (default: 300)
POLLING_INTERVAL_EVENTS=300

# --- Alert Behaviour --------------------------------------------------------

# Maximum push alerts per 10-minute window per channel (default: 6)
ALERT_RATE_LIMIT_PER_10MIN=6

# Discard tokens older than this many hours from scoring (default: 4)
MAX_TOKEN_AGE_HOURS=4

# Minimum confidence_score required to emit any alert (default: 0.25)
CONFIDENCE_FLOOR_FOR_ALERT=0.25
