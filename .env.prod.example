# Production mode — all API keys required, strict retention, JSON logging.
# Copy to .env for production deployment. DO NOT commit this file with real keys.

ENVIRONMENT=prod
DATABASE_PATH=/data/mctrend.db
LOG_LEVEL=INFO
LOG_FORMAT=json

# === REQUIRED for live ingestion ===
SOLANA_RPC_URL=https://api.mainnet-beta.solana.com
# PUMPFUN_API_URL=  # Leave empty to use default pump.fun endpoint

# === REQUIRED for news/trends narrative detection ===
NEWSAPI_KEY=your_production_newsapi_key
SERPAPI_KEY=your_production_serpapi_key

# === REQUIRED for alert delivery ===
# Choose one or more delivery channels:
TELEGRAM_BOT_TOKEN=your_bot_token
TELEGRAM_CHAT_ID=your_chat_id

# Webhook (optional — used in addition to Telegram)
WEBHOOK_URL=https://your-receiver.example.com/alerts
WEBHOOK_SECRET=your_hmac_signing_secret_at_least_32_chars

# === Operational tuning ===
POLLING_INTERVAL_TOKENS=30
POLLING_INTERVAL_EVENTS=300
ALERT_RATE_LIMIT_PER_10MIN=6
MAX_TOKEN_AGE_HOURS=4
CONFIDENCE_FLOOR_FOR_ALERT=0.25

# Retention (set conservatively for disk management)
CHAIN_SNAPSHOT_RETENTION_HOURS=48
SCORED_TOKEN_RETENTION_HOURS=72
RETIRED_ALERT_RETENTION_HOURS=168

# Ingestion parameters
NEWS_SIGNAL_STRENGTH=0.6
TRENDS_SIGNAL_STRENGTH=0.7
TRENDS_GEO=US
PUMPFUN_FETCH_LIMIT=50
NEWS_PAGE_SIZE=10
