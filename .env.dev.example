# Development mode — real APIs but non-production DB and verbose logging.
# Copy to .env for local development.

ENVIRONMENT=dev
DATABASE_PATH=data/mctrend_dev.db
LOG_LEVEL=DEBUG
LOG_FORMAT=console

# Data sources — populate to test live ingestion
SOLANA_RPC_URL=https://api.mainnet-beta.solana.com
PUMPFUN_API_URL=
NEWSAPI_KEY=your_newsapi_key_here
SERPAPI_KEY=your_serpapi_key_here

# Delivery — leave empty to use console only
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
WEBHOOK_URL=
WEBHOOK_SECRET=

# Tuning
POLLING_INTERVAL_TOKENS=60
POLLING_INTERVAL_EVENTS=300
ALERT_RATE_LIMIT_PER_10MIN=10
MAX_TOKEN_AGE_HOURS=6

# Retention
CHAIN_SNAPSHOT_RETENTION_HOURS=24
SCORED_TOKEN_RETENTION_HOURS=48
RETIRED_ALERT_RETENTION_HOURS=72
