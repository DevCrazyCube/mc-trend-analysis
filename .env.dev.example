# Development mode — real APIs but non-production DB and verbose logging.
# Copy to .env for local development.

ENVIRONMENT=dev
DATABASE_PATH=data/mctrend_dev.db
LOG_LEVEL=DEBUG
LOG_FORMAT=console

# --- Token Discovery ----------------------------------------------------------
# PumpPortal WebSocket: real-time new-token discovery (RECOMMENDED path).
# Connects to wss://pumpportal.fun/api/data and subscribes to new token events.
# Set to true to enable. Will reconnect automatically on disconnect.
PUMPPORTAL_WS_ENABLED=false
PUMPPORTAL_WS_URL=wss://pumpportal.fun/api/data
# PUMPPORTAL_WS_STALE_TIMEOUT_SECONDS=120

# PUMPFUN_API_URL: Token listing REST API base URL (fallback, optional).
# The default public endpoint (frontend-api-v2.pump.fun) is non-functional (persistent 503).
# Must point to a token LISTING endpoint that returns JSON at <URL>/coins — NOT a trading
# or execution endpoint (e.g. pumpportal.fun/api/trade returns 403 and is not a listing API).
# Leave empty to use WebSocket discovery only (recommended when WS is enabled).
PUMPFUN_API_URL=

# Solana RPC — used for on-chain enrichment of discovered tokens (not discovery)
SOLANA_RPC_URL=https://api.mainnet-beta.solana.com

# --- Data Sources -------------------------------------------------------------
NEWSAPI_KEY=your_newsapi_key_here
SERPAPI_KEY=your_serpapi_key_here

# --- X (Twitter) Emergent Narrative Detection ---------------------------------
# X detects emerging narratives/entities/topics from broad source material,
# then correlates spikes with token launches.  NOT a fixed-query crypto scanner.
# See: docs/ingestion/x-emergent-narrative-detection.md
X_API_BEARER_TOKEN=
X_ENABLED=false

# Discovery queries per cycle (rotated from broad category pool; default 10)
# X_QUERIES_PER_CYCLE=10

# Max API calls per pipeline cycle (X uses credit-based billing; default 10)
# X_MAX_REQUESTS_PER_CYCLE=10

# Base signal strength for X events before engagement weighting (0.0-1.0; default 0.5)
# X_SIGNAL_STRENGTH=0.5

# Rate-limit cooldown: enter exponential backoff after N consecutive 429s (default 2)
# X_COOLDOWN_AFTER=2

# Base cooldown duration in seconds (default 60); doubles per episode, capped at max
# X_COOLDOWN_SECONDS=60.0
# X_MAX_COOLDOWN_SECONDS=900.0

# Persistent cooldown state file (survives process restarts)
# X_RATE_LIMIT_STATE_PATH=data/x_ratelimit_state.json

# --- Operator Dashboard -------------------------------------------------------
# Start dashboard with: python -m mctrend --dashboard
# Then build the frontend: cd dashboard && npm install && npm run build
#
# Set DASHBOARD_API_KEY to require authentication. Leave empty for unrestricted
# local access (only safe on localhost / trusted VPN).
DASHBOARD_API_KEY=
DASHBOARD_HOST=127.0.0.1
DASHBOARD_PORT=8765

# --- Delivery -----------------------------------------------------------------
# Leave empty to use console only
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
WEBHOOK_URL=
WEBHOOK_SECRET=

# --- Tuning -------------------------------------------------------------------
POLLING_INTERVAL_TOKENS=60
POLLING_INTERVAL_EVENTS=300
ALERT_RATE_LIMIT_PER_10MIN=10
MAX_TOKEN_AGE_HOURS=6

# --- Retention ----------------------------------------------------------------
CHAIN_SNAPSHOT_RETENTION_HOURS=24
SCORED_TOKEN_RETENTION_HOURS=48
RETIRED_ALERT_RETENTION_HOURS=72
